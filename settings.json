{
    "chat.fontSize": 16,
    "console-ninja.featureSet": "Community",
    "custom-ui-style.font.monospace": "Kitan Mono",
    "custom-ui-style.font.sansSerif": "MD IO Trial",
    "editor.codeLens": false,
    "editor.foldingStrategy": "auto",
    "editor.fontFamily": "Kitan Mono",
    "editor.fontSize": 15,
    "editor.inlayHints.enabled": "off",
    "editor.inlayHints.fontFamily": "Kitan Mono",
    "editor.inlineSuggest.enabled": false,
    "editor.lightbulb.enabled": "off",
    "editor.lineHeight": 1.6,
    "editor.minimap.enabled": true,
    "editor.scrollbar.horizontal": "hidden",
    "editor.scrollBeyondLastColumn": 0,
    "editor.scrollbar.vertical": "hidden",
    "editor.showFoldingControls": "always",
    "editor.stickyScroll.enabled": true,
    "editor.wordWrap": "bounded",
    "editor.wordWrapColumn": 120,
    "editor.minimap.renderCharacters": false,
    "errorLens.followCursor": "activeLine",
    "errorLens.fontSize": "13",
    "errorLens.messageMaxChars": 50,
    "errorLens.scrollbarHackEnabled": true,
    //outline view settings
    "outline.collapseItems": "alwaysCollapse",
    "outline.showConstants": false,
    "outline.showFields": false,
    "outline.showObjects": true,
    "outline.showStructs": true,
    "outline.showVariables": false,
    "python.envFile": "${workspaceFolder}/.env",
    "python.terminal.useEnvFile": true,
    "terminal.integrated.fontFamily": "Kitan Mono",
    "terminal.integrated.fontSize": 15,
    "workbench.colorTheme": "Mayukai Mirage Gruvbox Darktooth",
    "workbench.iconTheme": "catppuccin-mocha",
    "workbench.sideBar.location": "right",
    "diffEditor.hideUnchangedRegions.enabled": true,
    "explorer.compactFolders": true,
    "workbench.editor.enablePreview": true,
    "editor.minimap.size": "fit",
    "basedpyright.analysis.diagnosticMode": "openFilesOnly",
    "editor.definitionLinkOpensInPeek": true,
    "explorer.fileNesting.patterns": {
        "*.ts": "${capture}.js",
        "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
        "*.jsx": "${capture}.js",
        "*.tsx": "${capture}.ts",
        "tsconfig.json": "tsconfig.*.json",
        "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
        "*.sqlite": "${capture}.${extname}-*",
        "*.db": "${capture}.${extname}-*",
        "*.sqlite3": "${capture}.${extname}-*",
        "*.db3": "${capture}.${extname}-*",
        "*.sdb": "${capture}.${extname}-*",
        "*.s3db": "${capture}.${extname}-*"
    },
    "workbench.editor.showTabs": "single",
    "nebulaOni.update.restoreConfiguration": {
        "themeSettings": {
            "background": "Grey",
            "main": "Bumblebee",
            "highlight": "Ultra Violet",
            "focusBorder": "ON",
            "fontStyle": "Italic",
            "syntaxBrightness": "Normal",
            "comments": "Dark Violet",
            "favorite": "OFF"
        },
        "favoriteSettings": {
            "background": "Glacial Blue",
            "main": "Sakura",
            "highlight": "Ultra Violet",
            "focusBorder": "ON",
            "fontStyle": "Italic",
            "syntaxBrightness": "Dimmed",
            "comments": "Dark Magenta",
            "favorite": "Nebula Oni (Pegasus)"
        }
    },
}